{
  "colors": {
    "primary": "#FFFFFF",
    "secondary": "#111111",
    "background": "#000000",
    "accent": "#FFFFFF"
  },
  "typography": {
    "fontFamily": "sans-serif",
    "sizes": {
      "xs": "10px",
      "sm": "11px",
      "md": "12px",
      "lg": "14px",
      "xl": "16px"
    },
    "weights": {
      "normal": 400,
      "medium": 500,
      "bold": 600
    }
  },
  "motion": {
    "easingCurves": {
      "smooth": "power2.out",
      "bouncy": "elastic.out(1, 0.5)",
      "precise": "power3.inOut",
      "natural": "sine.inOut"
    },
    "durations": {
      "short": 0.3,
      "medium": 0.6,
      "long": 1.2,
      "interaction": 0.2
    },
    "defaults": {
      "ease": "power2.out",
      "duration": 0.6,
      "stagger": 0.05
    }
  }
}
{
  "colors": {
    "primary": "#1a1a1a",
    "secondary": "#f5f5f5",
    "background": "#ffffff",
    "accent": "#000000"
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "bold": 700
    }
  },
  "motion": {
    "easingCurves": {
      "soft": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "sharp": "cubic-bezier(0.4, 0, 0.6, 1)",
      "spring": "cubic-bezier(0.22, 1, 0.36, 1)",
      "easeOut": "cubic-bezier(0.25, 0.46, 0.45, 1)",
      "easeIn": "cubic-bezier(0.42, 0, 1, 1)"
    },
    "durations": {
      "short": 0.2,
      "default": 0.5,
      "long": 0.8,
      "slow": 1.2
    },
    "threejsDefaults": {
      "rotationSpeed": 0.005,
      "transitionDelay": 0.1,
      "staggerAmount": 0.05,
      "cameraEase": "spring(50, 10, 0, 0)",
      "objectEase": "cubic-bezier(0.25, 0.46, 0.45, 0.94)"
    },
    "gsapExtensions": [
      "InertiaPlugin",
      "PixiPlugin",
      "ScrollTrigger",
      "GSDevTools"
    ]
  }
}